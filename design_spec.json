{
  "meta": {
    "version": "2.0.0",
    "app_name": "KidsEdu",
    "target_age": "4-5세",
    "design_direction": "아동 친화 파스텔 톤 — 둥글고 부드러운 UI, 큰 터치 타겟, 밝고 따뜻한 색감",
    "benchmarks": ["LetterSchool", "Writing Wizard", "Khan Academy Kids", "핑크퐁", "Sago Mini World"],
    "mascot": {
      "name": "또리",
      "type": "곰 캐릭터",
      "format": "SVG inline",
      "growth_levels": 10,
      "idle_animation": "floating 2s ease-in-out infinite"
    }
  },

  "design_principles": [
    { "id": "DP-1", "name": "둥글고 부드럽게", "rule": "모든 모서리 border-radius 16px+, 직각 없음" },
    { "id": "DP-2", "name": "크고 또렷하게", "rule": "최소 폰트 16px, 주요 글자 80px+, 아이콘 32px+" },
    { "id": "DP-3", "name": "밝고 따뜻하게", "rule": "크림색 배경, 파스텔 포인트 색상" },
    { "id": "DP-4", "name": "움직이고 반응하게", "rule": "모든 터치에 바운스/반짝임 피드백" },
    { "id": "DP-5", "name": "단순하게", "rule": "화면당 핵심 액션 1개, 선택지 최대 4-6개" },
    { "id": "DP-6", "name": "긍정적 강화", "rule": "실패 없는 설계 — 틀려도 격려, 재시도 유도" }
  ],

  "colors": {
    "css_variable_prefix": "--color-",
    "backgrounds": {
      "bg-cream":       { "value": "#FFF8E7", "usage": "메인 배경 — 앱 전체 기본 배경색" },
      "bg-warm":        { "value": "#FFF3D6", "usage": "카드 배경 — 학습 카드, 게임 카드 배경" },
      "bg-soft":        { "value": "#F0F4FF", "usage": "게임 영역 배경 — 미니 게임, 캔버스 영역" },
      "bg-overlay":     { "value": "rgba(0,0,0,0.3)", "usage": "모달/다이얼로그 오버레이 배경" }
    },
    "primary": {
      "primary-blue":       { "value": "#4A90D9", "usage": "주 액션 버튼, 네비게이션 활성 탭, 링크" },
      "primary-blue-light": { "value": "#7CB3E8", "usage": "호버/활성 상태, 진행도 링 배경" },
      "primary-blue-dark":  { "value": "#3A72B0", "usage": "눌림 상태 (pressed)" }
    },
    "accent": {
      "accent-yellow":  { "value": "#FFD93D", "usage": "별, 보상, 하이라이트, 스트리크 배너" },
      "accent-orange":  { "value": "#FF9F43", "usage": "CTA 버튼, 주의 끌기, 점 잇기 포인트" },
      "success-green":  { "value": "#2ED573", "usage": "성공/완료 상태, 올바른 정렬 위치" },
      "reward-pink":    { "value": "#FF6B81", "usage": "특별 보상, 트로피, 레벨업" },
      "error-coral":    { "value": "#FF6348", "usage": "부드러운 에러 피드백 (빨간색 대신 코랄)" }
    },
    "category": {
      "numbers-purple": { "value": "#A29BFE", "usage": "숫자 학습 카테고리 테마 색상" },
      "hangul-green":   { "value": "#55E6C1", "usage": "한글 학습 카테고리 테마 색상" },
      "english-orange": { "value": "#FECA57", "usage": "영어 학습 카테고리 테마 색상" },
      "games-pink":     { "value": "#FF9FF3", "usage": "게임 카테고리 테마 색상" }
    },
    "text": {
      "text-dark":   { "value": "#2D3436", "usage": "본문 텍스트, 주요 라벨" },
      "text-medium": { "value": "#636E72", "usage": "보조 텍스트, 설명" },
      "text-light":  { "value": "#B2BEC3", "usage": "비활성 텍스트, 플레이스홀더" },
      "text-white":  { "value": "#FFFFFF", "usage": "어두운 배경 위 텍스트, 버튼 라벨" }
    },
    "canvas": {
      "guide-color":  { "value": "rgba(74, 144, 217, 0.2)", "usage": "따라쓰기 가이드 글자 (1단계)" },
      "guide-faint":  { "value": "rgba(74, 144, 217, 0.1)", "usage": "자유쓰기 배경 글자 (3단계)" },
      "guide-medium": { "value": "rgba(74, 144, 217, 0.3)", "usage": "점잇기 배경 글자 (2단계)" },
      "stroke-color": { "value": "#4A90D9", "usage": "사용자 필기선 색상" },
      "dot-color":    { "value": "#FF9F43", "usage": "점 잇기 포인트 색상" },
      "dot-active":   { "value": "#FFD93D", "usage": "현재 활성 점 (빛나는 상태)" },
      "success-rainbow": { "value": "linear-gradient(90deg, #FF6B6B, #FFA500, #FFD93D, #2ED573, #4A90D9, #A29BFE, #FF6B81)", "usage": "자유쓰기 완료 시 무지개색 전환" }
    },
    "game_specific": {
      "coloring-palette": ["#FF6B6B", "#FFA500", "#FFD93D", "#2ED573", "#4A90D9", "#A29BFE"],
      "balloon-colors": ["#FF6B81", "#4A90D9", "#2ED573", "#FFD93D", "#A29BFE", "#FF9FF3"],
      "bubble-colors": ["#7CB3E8", "#A29BFE", "#55E6C1", "#FECA57", "#FF9FF3", "#FF6B81"]
    }
  },

  "typography": {
    "font_families": {
      "korean": {
        "family": "Pretendard Variable, Pretendard, -apple-system, system-ui, sans-serif",
        "source": "CDN (cdn.jsdelivr.net)",
        "weights": [400, 500, 600, 700],
        "usage": "한글 텍스트, UI 라벨, 본문"
      },
      "latin_numeric": {
        "family": "'Nunito', sans-serif",
        "source": "Google Fonts",
        "weights": [400, 600, 700, 800],
        "usage": "영문/숫자 학습 글자, 카드 타이틀, 점수 표시",
        "note": "둥근 형태로 아동 친화적"
      }
    },
    "scale": {
      "learning-char-xl": { "size": "120px", "weight": 800, "font": "Nunito", "usage": "숫자 학습 상세 — 메인 숫자" },
      "learning-char-lg": { "size": "100px", "weight": 700, "font": "Nunito/Pretendard", "usage": "한글/영문 학습 상세 — 메인 글자" },
      "learning-char-md": { "size": "80px",  "weight": 700, "font": "Nunito/Pretendard", "usage": "카드 그리드 내 학습 글자" },
      "heading-xl":       { "size": "32px",  "weight": 700, "font": "Pretendard", "usage": "화면 제목 (홈 인사말)" },
      "heading-lg":       { "size": "24px",  "weight": 700, "font": "Nunito", "usage": "카드 타이틀, 게임 이름" },
      "heading-md":       { "size": "20px",  "weight": 600, "font": "Pretendard", "usage": "섹션 헤딩, 탭 타이틀" },
      "body-lg":          { "size": "18px",  "weight": 400, "font": "Pretendard", "usage": "대표 단어, 설명 텍스트" },
      "body-md":          { "size": "16px",  "weight": 400, "font": "Pretendard", "usage": "본문, 안내 텍스트" },
      "label-lg":         { "size": "16px",  "weight": 500, "font": "Pretendard", "usage": "네비게이션 라벨, 버튼 텍스트" },
      "label-md":         { "size": "14px",  "weight": 500, "font": "Pretendard", "usage": "보조 라벨, 배지 텍스트" },
      "label-sm":         { "size": "12px",  "weight": 500, "font": "Pretendard", "usage": "캡션, 힌트 텍스트" }
    },
    "line_heights": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75
    }
  },

  "spacing": {
    "unit": "4px (0.25rem)",
    "scale": {
      "xs":   "4px",
      "sm":   "8px",
      "md":   "12px",
      "lg":   "16px",
      "xl":   "20px",
      "2xl":  "24px",
      "3xl":  "32px",
      "4xl":  "40px",
      "5xl":  "48px",
      "6xl":  "64px"
    },
    "page_padding": "16px (모바일) / 24px (태블릿)",
    "card_padding": "16px 내부 / 12px 카드 간 갭",
    "section_gap": "24px",
    "safe_area": "env(safe-area-inset-top/bottom/left/right)"
  },

  "borders": {
    "radius": {
      "sm":   "8px",
      "md":   "12px",
      "lg":   "16px",
      "xl":   "20px",
      "2xl":  "24px",
      "full": "9999px",
      "card": "20px",
      "button": "16px",
      "avatar": "9999px",
      "canvas": "24px"
    },
    "width": {
      "thin":   "1px",
      "medium": "2px",
      "thick":  "3px"
    }
  },

  "shadows": {
    "card":    "0 4px 12px rgba(0,0,0,0.08)",
    "card-hover": "0 8px 24px rgba(0,0,0,0.12)",
    "button":  "0 2px 8px rgba(74,144,217,0.25)",
    "button-pressed": "0 1px 4px rgba(74,144,217,0.15)",
    "nav":     "0 -2px 12px rgba(0,0,0,0.06)",
    "modal":   "0 16px 48px rgba(0,0,0,0.2)",
    "reward":  "0 0 20px rgba(255,217,61,0.5)",
    "glow":    "0 0 16px rgba(74,144,217,0.4)"
  },

  "breakpoints": {
    "mobile":  { "min": "360px", "max": "767px" },
    "tablet":  { "min": "768px", "max": "1024px", "note": "주 타겟 디바이스" },
    "desktop": { "min": "1025px", "max_content": "1024px", "note": "중앙 정렬, max-width 제한" }
  },

  "touch": {
    "min_target_size": "56px",
    "recommended_target_size": "64px",
    "card_min_height": "80px",
    "nav_item_height": "64px",
    "learning_card_size": {
      "mobile": "min(calc(50vw - 24px), 160px)",
      "tablet": "min(calc(33vw - 24px), 180px)"
    }
  },

  "animations": {
    "library": "Motion 12 (구 Framer Motion)",
    "durations": {
      "instant":  "100ms",
      "fast":     "200ms",
      "normal":   "300ms",
      "slow":     "500ms",
      "reward":   "1000ms",
      "confetti": "3000ms",
      "idle":     "2000ms"
    },
    "easings": {
      "default":     "ease-out",
      "spring":      { "type": "spring", "stiffness": 300, "damping": 20 },
      "bounce":      { "type": "spring", "stiffness": 400, "damping": 10 },
      "gentle":      { "type": "spring", "stiffness": 200, "damping": 25 }
    },
    "presets": {
      "page_transition": {
        "initial":  { "opacity": 0, "x": 50 },
        "animate":  { "opacity": 1, "x": 0 },
        "exit":     { "opacity": 0, "x": -50 },
        "transition": { "duration": 0.3, "ease": "easeOut" }
      },
      "card_entrance": {
        "initial":  { "opacity": 0, "y": 20 },
        "animate":  { "opacity": 1, "y": 0 },
        "transition": { "staggerChildren": 0.05 }
      },
      "button_tap": {
        "whileTap": { "scale": 0.95 },
        "transition": { "type": "spring", "stiffness": 400, "damping": 17 }
      },
      "star_earned": {
        "description": "별이 회전하며 날아와 헤더에 흡수",
        "initial":  { "scale": 0, "rotate": 0, "opacity": 0 },
        "animate":  { "scale": [0, 1.5, 1], "rotate": [0, 360], "opacity": 1 },
        "transition": { "duration": 0.8, "ease": "easeOut" }
      },
      "level_up": {
        "description": "화면 전체 축하 파티클 3초",
        "particles": true,
        "duration": 3000
      },
      "tracing_complete": {
        "description": "글자가 무지개색으로 변환",
        "duration": 1000
      },
      "mascot_idle": {
        "description": "부유 애니메이션",
        "animate": { "y": [0, -8, 0] },
        "transition": { "duration": 2, "repeat": "Infinity", "ease": "easeInOut" }
      },
      "balloon_float": {
        "description": "풍선 떠오르기",
        "initial": { "y": "100vh", "scale": 0.8 },
        "animate": { "y": "-10vh", "scale": 1, "rotate": [-5, 5, -5] },
        "transition": { "duration": 6, "ease": "linear" }
      },
      "confetti_burst": {
        "description": "컨페티 폭발 효과",
        "particles": 50,
        "spread": 360,
        "duration": 3000,
        "colors": ["#FFD93D", "#FF6B81", "#4A90D9", "#2ED573", "#A29BFE", "#FF9FF3"]
      },
      "card_flip": {
        "description": "카드 뒤집기 (메모리 매치)",
        "duration": 400,
        "transition": { "rotateY": [0, 180] }
      },
      "shake_wrong": {
        "description": "오답 시 흔들림",
        "animate": { "x": [-4, 4, -4, 4, 0] },
        "transition": { "duration": 0.4 }
      }
    }
  },

  "sounds": {
    "engine": "Web Audio API",
    "source": "Freesound.org CC0",
    "effects": {
      "button_click":     { "description": "짧은 뽁 효과음",            "duration": "100ms" },
      "correct":          { "description": "밝은 띵! 차임",             "duration": "300ms" },
      "wrong":            { "description": "부드러운 부웅",             "duration": "400ms", "note": "부정적이지 않은 톤" },
      "star_earned":      { "description": "반짝반짝 효과음",           "duration": "500ms" },
      "level_up":         { "description": "팡파레",                   "duration": "1500ms" },
      "stroke_draw":      { "description": "크레용 질감 사운드",         "duration": "continuous" },
      "stroke_complete":  { "description": "짧은 딩 + 반짝임",          "duration": "200ms" },
      "confetti":         { "description": "파팟 효과음",               "duration": "500ms" },
      "balloon_pop":      { "description": "풍선 터지는 소리",           "duration": "200ms" },
      "card_flip":        { "description": "카드 뒤집는 소리",           "duration": "150ms" },
      "match_success":    { "description": "매칭 성공 차임",            "duration": "400ms" },
      "drag_pickup":      { "description": "들어올리기 톡",             "duration": "100ms" },
      "drag_drop":        { "description": "놓기 착",                  "duration": "150ms" },
      "encouragement":    { "description": "마스코트 격려 (다시 해볼까?)", "type": "TTS" }
    },
    "settings": {
      "master_volume": 0.7,
      "sfx_volume": 0.8,
      "tts_volume": 1.0,
      "mute_toggle": true
    }
  },

  "canvas_spec": {
    "technology": "HTML5 Canvas API (라이브러리 미사용)",
    "layers": [
      { "order": 0, "name": "background-text", "description": "실제 글자 (가이드 텍스트) — opacity 단계별 변화" },
      { "order": 1, "name": "guide-dots",      "description": "현재 획 점선 경로 / 번호 매긴 점 (1-2단계)" },
      { "order": 2, "name": "user-input",      "description": "사용자 활성 드로잉 레이어" }
    ],
    "dimensions": {
      "min_size": "280px × 280px",
      "max_size": "400px × 400px",
      "responsive": true,
      "dpi_scaling": "window.devicePixelRatio"
    },
    "input": {
      "event_type": "PointerEvent (터치/마우스/펜 통합)",
      "touch_action": "none (스크롤 방지)",
      "line_width": "12px",
      "line_cap": "round",
      "line_join": "round",
      "smoothing": "quadraticCurveTo"
    },
    "tracing_stages": {
      "stage_1_guided": {
        "name": "따라가기",
        "guide_opacity": 0.3,
        "show_dotted_path": true,
        "show_start_indicator": true,
        "start_indicator": "빛나는 원형 (pulse 애니메이션)",
        "path_tolerance": "20px",
        "off_path_behavior": "부드럽게 재안내 (격려 메시지)"
      },
      "stage_2_dots": {
        "name": "점 잇기",
        "guide_opacity": 0.3,
        "show_numbered_dots": true,
        "dot_size": "16px",
        "dot_reach_effect": "팡 + 다음 점 활성화",
        "dot_active_glow": true
      },
      "stage_3_free": {
        "name": "자유 쓰기",
        "guide_opacity": 0.1,
        "no_guides": true,
        "success_threshold": "글자 영역 60% 이상 커버",
        "success_effect": "무지개색 전환 + 축하 애니메이션"
      }
    },
    "feedback": {
      "in_progress": "펜 경로에 반짝이는 파티클 트레일",
      "stroke_complete": "짧은 딩 효과음 + 반짝임",
      "stage_complete": "마스코트 격려 + 별 1개",
      "all_complete": "축하 컨페티 + 별 3개 + 레벨업 체크"
    },
    "controls": {
      "buttons": ["지우기 (↺)", "다시쓰기", "다음 단계 (→)"],
      "button_position": "캔버스 하단",
      "button_min_size": "56px"
    }
  },

  "components": {
    "layout": {
      "AppLayout": {
        "description": "전체 앱 레이아웃 래퍼",
        "file": "src/components/ui/AppLayout.tsx",
        "props": ["children"],
        "structure": "TopBar + main content (flex-1 overflow-y-auto) + BottomNav",
        "styles": {
          "background": "bg-cream",
          "min_height": "100dvh",
          "max_width": "1024px (데스크톱 중앙 정렬)",
          "safe_area": "padding: env(safe-area-inset)"
        }
      },
      "TopBar": {
        "description": "상단 바 — 마스코트 + 인사말 + 레벨 뱃지 + 별 카운터",
        "file": "src/components/ui/TopBar.tsx",
        "props": ["level", "stars", "streak"],
        "height": "64px",
        "elements": [
          { "name": "mascot-avatar", "size": "40px", "shape": "circle" },
          { "name": "greeting-text", "style": "heading-xl", "dynamic": "시간대별 인사" },
          { "name": "level-badge", "shape": "pill", "bg": "accent-yellow" },
          { "name": "star-counter", "icon": "star SVG", "font": "Nunito Bold" }
        ]
      },
      "BottomNav": {
        "description": "하단 탭 네비게이션 — 5개 탭",
        "file": "src/components/ui/BottomNav.tsx",
        "props": ["activeTab"],
        "height": "64px + safe-area-inset-bottom",
        "shadow": "0 -2px 12px rgba(0,0,0,0.06)",
        "background": "#FFFFFF",
        "border_radius_top": "20px",
        "tabs": [
          { "id": "home",    "label": "홈",  "icon": "HomeIcon SVG",    "color_active": "primary-blue" },
          { "id": "numbers", "label": "숫자", "icon": "NumbersIcon SVG", "color_active": "numbers-purple" },
          { "id": "hangul",  "label": "한글", "icon": "HangulIcon SVG",  "color_active": "hangul-green" },
          { "id": "english", "label": "영어", "icon": "EnglishIcon SVG", "color_active": "english-orange" },
          { "id": "games",   "label": "게임", "icon": "GamesIcon SVG",   "color_active": "games-pink" }
        ],
        "tab_spec": {
          "icon_size": "32px",
          "label_font": "label-md",
          "min_touch_target": "56px",
          "active_indicator": "filled icon + color label",
          "inactive_color": "text-light"
        }
      }
    },

    "ui_primitives": {
      "Button": {
        "description": "공통 버튼 — 다양한 variant 지원",
        "file": "src/components/ui/Button.tsx",
